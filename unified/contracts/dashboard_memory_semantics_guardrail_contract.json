{
  "dashboard_path": "monitoring/grafana/dashboards/openbrain/openbrain-overview.json",
  "required_panels": [
    {
      "title": "Active Memories (All incl Test Data)",
      "expr": "active_memories_all_total{job=\"openbrain-unified\"}"
    },
    {
      "title": "Active Memories (Visible Excl Test Data)",
      "expr": "active_memories_total{job=\"openbrain-unified\"}"
    },
    {
      "title": "Hidden Test Data (Active Only)",
      "expr": "hidden_test_data_active_total{job=\"openbrain-unified\"}"
    },
    {
      "title": "Hidden Test Data Share (Active)",
      "expr": "hidden_test_data_active_total{job=\"openbrain-unified\"} / clamp_min(active_memories_all_total{job=\"openbrain-unified\"}, 1)"
    }
  ]
}
