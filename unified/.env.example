# OpenBrain Unified — Environment Configuration
# Copy to unified/.env and edit before running:
#   cp unified/.env.example unified/.env

# REQUIRED: Random secret for internal API access (change before use!)
INTERNAL_API_KEY=change-me-before-use

# Database (matches docker-compose.unified.yml defaults)
DATABASE_URL=postgresql+asyncpg://openbrain:openbrain@localhost:5433/openbrain

# Embeddings (Ollama running locally or in Docker)
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# Set to false for local development (disables auth enforcement)
PUBLIC_MODE=false

# Uncomment for production/public mode:
# PUBLIC_BASE_URL=https://your-domain.com
# OIDC_ISSUER_URL=https://your-oidc-provider.com

# Optional: Redis for shared rate limiting (falls back to in-memory)
# REDIS_URL=redis://localhost:6379/0

# Optional: Telemetry backend (memory or redis)
# TELEMETRY_BACKEND=memory
