# OpenBrain Unified v2.0 — Environment Variables
# Copy to .env — NEVER commit .env

# --- Ngrok (external access) ---
# Set ENABLE_NGROK=1 only when you explicitly want the public tunnel profile.
ENABLE_NGROK=false
NGROK_AUTHTOKEN=
NGROK_URL=your-domain.ngrok-free.dev

# --- Public mode (required for ChatGPT MCP via ngrok) ---
PUBLIC_MODE=false
PUBLIC_BASE_URL=https://your-domain.ngrok-free.dev

# --- Auth0 OIDC (required when PUBLIC_MODE=true) ---
OIDC_ISSUER_URL=https://your-tenant.eu.auth0.com
OIDC_AUDIENCE=https://openbrain-mcp
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# --- Internal API key (MCP gateway → backend bypass) ---
# Leave empty by default. In PUBLIC_MODE=true you must set a unique secret.
INTERNAL_API_KEY=

# --- Monitoring ---
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
# Set explicitly before first start in any shared or public deployment.
GRAFANA_ADMIN_PASSWORD=

# --- Rate limiting (Redis) ---
# Default: Redis service defined in docker-compose (redis://redis:6379/0).
# In PUBLIC_MODE=true, memory:// is rejected at startup — set a real Redis URL.
# Local dev without Docker: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# --- Database ---
# Dev defaults are allowed only for fully local use.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=openbrain_unified
