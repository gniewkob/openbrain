<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openbrain.postgres-backup</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>/Users/gniewkob/Repos/openbrain/scripts/backup_postgres.sh --full</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/gniewkob/Repos/openbrain</string>

    <!-- codziennie o 03:00 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- żeby docker był w PATH -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/gniewkob/Repos/openbrain/backups/backup-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/gniewkob/Repos/openbrain/backups/backup-stderr.log</string>

    <!-- nie uruchamiaj przy boocie, tylko o wyznaczonej godzinie -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
